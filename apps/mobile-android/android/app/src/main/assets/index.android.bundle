"\u0110\u1eb7t h\xe0ng",question:"\u0110\u01a1n h\xe0ng c\u1ee7a t\xf4i \u1edf \u0111\xe2u r\u1ed3i?",answer:"V\xe0o tab \u0110\u01a1n h\xe0ng \u2192 Ch\u1ecdn \u0111\u01a1n h\xe0ng \u0111ang giao \u2192 Xem b\u1ea3n \u0111\u1ed3 theo d\xf5i th\u1eddi gian th\u1ef1c. B\u1ea1n c\u0169ng c\xf3 th\u1ec3 nh\u1eafn tin tr\u1ef1c ti\u1ebfp v\u1edbi shipper trong ph\u1ea7n \u0111\u01a1n h\xe0ng."},{id:"5",category:"Thanh to\xe1n",question:"FoodBee h\u1ed7 tr\u1ee3 nh\u1eefng ph\u01b0\u01a1ng th\u1ee9c thanh to\xe1n n\xe0o?",answer:"FoodBee h\u1ed7 tr\u1ee3 2 ph\u01b0\u01a1ng th\u1ee9c: (1) Ti\u1ec1n m\u1eb7t \u2013 thanh to\xe1n khi nh\u1eadn h\xe0ng. (2) Chuy\u1ec3n kho\u1ea3n qua PayOS \u2013 thanh to\xe1n online an to\xe0n, ti\u1ec7n l\u1ee3i."},{id:"6",category:"Thanh to\xe1n",question:"T\xf4i thanh to\xe1n online nh\u01b0ng ch\u01b0a th\u1ea5y \u0111\u01a1n \u0111\u01b0\u1ee3c x\xe1c nh\u1eadn?",answer:"Sau khi thanh to\xe1n PayOS th\xe0nh c\xf4ng, h\u1ec7 th\u1ed1ng s\u1ebd t\u1ef1 \u0111\u1ed9ng x\xe1c nh\u1eadn trong v\xf2ng 1\u20132 ph\xfat. N\u1ebfu qu\xe1 5 ph\xfat v\u1eabn ch\u01b0a th\u1ea5y, vui l\xf2ng li\xean h\u1ec7 h\u1ed7 tr\u1ee3 qua s\u1ed1 hotline."},{id:"7",category:"Thanh to\xe1n",question:"T\xf4i c\xf3 \u0111\u01b0\u1ee3c ho\xe0n ti\u1ec1n khi h\u1ee7y \u0111\u01a1n kh\xf4ng?",answer:"N\u1ebfu b\u1ea1n \u0111\xe3 thanh to\xe1n online v\xe0 h\u1ee7y \u0111\u01a1n tr\u01b0\u1edbc khi shipper nh\u1eadn, kho\u1ea3n thanh to\xe1n s\u1ebd \u0111\u01b0\u1ee3c ho\xe0n l\u1ea1i trong 3\u20135 ng\xe0y l\xe0m vi\u1ec7c t\xf9y ng\xe2n h\xe0ng."},{id:"8",category:"Voucher & Xu",question:"M\xe3 gi\u1ea3m gi\xe1 c\u1ee7a t\xf4i kh\xf4ng d\xf9ng \u0111\u01b0\u1ee3c?",answer:"Vui l\xf2ng ki\u1ec3m tra: (1) C\xf2n h\u1ea1n s\u1eed d\u1ee5ng ch\u01b0a. (2) Gi\xe1 tr\u1ecb \u0111\u01a1n h\xe0ng \u0111\xe3 \u0111\u1ea1t m\u1ee9c t\u1ed1i thi\u1ec3u ch\u01b0a. (3) Voucher c\xf3 \xe1p d\u1ee5ng cho nh\xe0 h\xe0ng \u0111ang \u0111\u1eb7t kh\xf4ng. M\u1ed7i voucher ch\u1ec9 d\xf9ng \u0111\u01b0\u1ee3c 1 l\u1ea7n."},{id:"9",category:"Voucher & Xu",question:"FoodBee Xu l\xe0 g\xec? D\xf9ng nh\u01b0 th\u1ebf n\xe0o?",answer:"FoodBee Xu l\xe0 \u0111i\u1ec3m th\u01b0\u1edfng t\xedch l\u0169y sau m\u1ed7i \u0111\u01a1n h\xe0ng ho\xe0n th\xe0nh. B\u1ea1n c\xf3 th\u1ec3 d\xf9ng Xu \u0111\u1ec3 gi\u1ea3m tr\u1ef1c ti\u1ebfp v\xe0o t\u1ed5ng ti\u1ec1n \u0111\u01a1n h\xe0ng, 1 Xu = 1.000\u0111 gi\u1ea3m gi\xe1."},{id:"10",category:"T\xe0i kho\u1ea3n",question:"L\xe0m th\u1ebf n\xe0o \u0111\u1ec3 thay \u0111\u1ed5i \u0111\u1ecba ch\u1ec9 giao h\xe0ng?",answer:"V\xe0o tab T\xf4i \u2192 \u0110\u1ecba ch\u1ec9 nh\u1eadn h\xe0ng \u2192 Th\xeam \u0111\u1ecba ch\u1ec9 m\u1edbi ho\u1eb7c ch\u1ec9nh s\u1eeda \u0111\u1ecba ch\u1ec9 hi\u1ec7n t\u1ea1i. Khi \u0111\u1eb7t h\xe0ng, b\u1ea1n c\xf3 th\u1ec3 ch\u1ecdn \u0111\u1ecba ch\u1ec9 t\u1eeb danh s\xe1ch \u0111\xe3 l\u01b0u."},{id:"11",category:"T\xe0i kho\u1ea3n",question:"T\xf4i qu\xean m\u1eadt kh\u1ea9u, ph\u1ea3i l\xe0m sao?",answer:"T\u1ea1i m\xe0n h\xecnh \u0111\u0103ng nh\u1eadp, nh\u1ea5n \"Qu\xean m\u1eadt kh\u1ea9u\" \u2192 Nh\u1eadp email \u0111\u0103ng k\xfd \u2192 L\xe0m theo h\u01b0\u1edbng d\u1eabn trong email \u0111\u1ec3 \u0111\u1eb7t l\u1ea1i m\u1eadt kh\u1ea9u."},{id:"12",category:"Tr\u1edf th\xe0nh T\xe0i x\u1ebf",question:"L\xe0m th\u1ebf n\xe0o \u0111\u1ec3 \u0111\u0103ng k\xfd l\xe0m t\xe0i x\u1ebf FoodBee?",answer:"V\xe0o tab T\xf4i \u2192 H\u1ee3p t\xe1c T\xe0i x\u1ebf FoodBee \u2192 \u0110\u0103ng k\xfd ngay. \u0110i\u1ec1n \u0111\u1ea7y \u0111\u1ee7 th\xf4ng tin c\xe1 nh\xe2n v\xe0 th\xf4ng tin ph\u01b0\u01a1ng ti\u1ec7n. Sau khi duy\u1ec7t, b\u1ea1n c\xf3 th\u1ec3 b\u1eaft \u0111\u1ea7u nh\u1eadn \u0111\u01a1n."}],P=["T\u1ea5t c\u1ea3","\u0110\u1eb7t h\xe0ng","Thanh to\xe1n","Voucher & Xu","T\xe0i kho\u1ea3n","Tr\u1edf th\xe0nh T\xe0i x\u1ebf"],y=function(e){var h=e.item,c=(0,n.useState)(!1),l=(0,t.default)(c,2),u=l[0],p=l[1],T=(0,n.useRef)(new i.Animated.Value(0)).current,P=